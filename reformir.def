Bootstrap: docker
From: pytorch/pytorch:2.6.0-cuda12.6-cudnn9-runtime

%post
    set -e

    # Install Java via tarball (apt-get requires privilege drop that fakeroot-less build can't do)
    # Eclipse Temurin 17 LTS - linux x64 tarball, no package manager needed
    JAVA_URL="https://github.com/adoptium/temurin17-binaries/releases/download/jdk-17.0.11%2B9/OpenJDK17U-jdk_x64_linux_hotspot_17.0.11_9.tar.gz"
    mkdir -p /opt/java
    python -c "import urllib.request; urllib.request.urlretrieve('https://github.com/adoptium/temurin17-binaries/releases/download/jdk-17.0.11%2B9/OpenJDK17U-jdk_x64_linux_hotspot_17.0.11_9.tar.gz', '/tmp/java.tar.gz')"
    tar -xzf /tmp/java.tar.gz -C /opt/java --strip-components=1
    rm /tmp/java.tar.gz
    export JAVA_HOME=/opt/java
    export PATH=$JAVA_HOME/bin:$PATH

    # Fail loudly if java not actually installed
    java -version

    # Install Python deps
    pip install --no-cache-dir \
        pyterrier==1.0.1 \
        pyterrier-adaptive==0.2.0 \
        pyterrier-alpha==0.16.4 \
        pyterrier-dr==0.6.2 \
        pyterrier-t5==0.2.1 \
        querygym==0.1.5 \
        pytrec-eval-terrier==0.5.10 \
        ir-datasets \
        ir-measures \
        pandas \
        scipy \
        numpy \
        "transformers<5" \
        "tokenizers<0.21" \
        "trl>=0.9.0" \
        "peft>=0.10.0" \
        datasets \
        accelerate

%environment
    export JAVA_HOME=/opt/java
    export PATH=$JAVA_HOME/bin:$PATH

%labels
    Author vvjumle
    Description ReformIR replication environment — torch 2.4.1, Temurin JDK 17
